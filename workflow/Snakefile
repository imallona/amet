        """
        Rscript workflow/scripts/generate_wcvi_sweep.R \
            --out_dir {params.out_dir} --seed {params.seed}
        """


rule run_amet_wcvi_sweep:
    input:
        manifest = op.join(SIM, "data", "wcvi_sweep", "manifest.tsv"),
        cpgs = op.join(SIM, "data", "wcvi_sweep", "cpgs.tsv"),
        bed = op.join(SIM, "data", "wcvi_sweep", "feature.bed"),
        binary = AMET,
    output:
        cell_feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.cell_feature.tsv.gz"),
        feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.feature.tsv.gz"),
        pair_counts = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.pair_counts.tsv.gz"),
    params:
        prefix = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep"),
    benchmark: op.join(SIM, "benchmarks", "run_amet_wcvi_sweep.tsv")
    log: op.join(SIM, "logs", "run_amet_wcvi_sweep.log")
    shell:
        """
        mkdir -p $(dirname {params.prefix})
        {input.binary} --cpg-reference {input.cpgs} --features {input.bed} \
            --cells {input.manifest} --output-prefix {params.prefix} \
            --i-max-lag 20 --min-cpgs-per-feature 5 &> {log}
        """


rule eval_wcvi_recovery:
    input:
        cell_feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.cell_feature.tsv.gz"),
        feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.feature.tsv.gz"),
