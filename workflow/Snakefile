rule eval_benchmark_summary:
    input:
        wcvi_cell_feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.cell_feature.tsv.gz"),
        wcvi_feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.feature.tsv.gz"),
        wcvi_pair_counts = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.pair_counts.tsv.gz"),
        acvi_cell_feature = op.join(SIM, "amet", "acvi_sweep", "acvi_sweep.cell_feature.tsv.gz"),
        acvi_feature = op.join(SIM, "amet", "acvi_sweep", "acvi_sweep.feature.tsv.gz"),
        acvi_pair_counts = op.join(SIM, "amet", "acvi_sweep", "acvi_sweep.pair_counts.tsv.gz"),
    output: op.join(SIM, "eval", "benchmark_summary.pdf")
    params: prefix = op.join(SIM, "eval", "benchmark_summary")
    shell:
        "Rscript workflow/scripts/eval_benchmark_summary.R "
        "--wcvi_cell_feature {input.wcvi_cell_feature} "
        "--wcvi_feature {input.wcvi_feature} "
        "--wcvi_pair_counts {input.wcvi_pair_counts} "
        "--acvi_cell_feature {input.acvi_cell_feature} "
        "--acvi_feature {input.acvi_feature} "
        "--acvi_pair_counts {input.acvi_pair_counts} "
        "--output_prefix {params.prefix}"


# ----- External tool comparisons (scMET, epiCHAOS) -----
# Each tool rule emits a benchmark TSV (CPU + memory) and a stderr log so we can
# compare runtime / footprint across amet, scMET, epiCHAOS in eval_tool_comparison.

R_TOOLS_ENV = op.join(REPO_ROOT, "workflow", "envs", "r-tools.yml")

rule run_scmet_wcvi:
    input: cell_feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.cell_feature.tsv.gz"),
    output: op.join(SIM, "scmet", "wcvi_sweep.scmet.tsv")
    threads: 4
    conda: R_TOOLS_ENV
    benchmark: op.join(SIM, "benchmarks", "run_scmet_wcvi.tsv")
    log: op.join(SIM, "logs", "run_scmet_wcvi.log")
    shell:
        "Rscript workflow/scripts/run_scmet.R "
        "--cell_feature {input.cell_feature} --output {output} --threads {threads} "
        "&> {log}"


rule run_scmet_acvi:
    input: cell_feature = op.join(SIM, "amet", "acvi_sweep", "acvi_sweep.cell_feature.tsv.gz"),
    output: op.join(SIM, "scmet", "acvi_sweep.scmet.tsv")
    threads: 4
    conda: R_TOOLS_ENV
    benchmark: op.join(SIM, "benchmarks", "run_scmet_acvi.tsv")
    log: op.join(SIM, "logs", "run_scmet_acvi.log")
    shell:
        "Rscript workflow/scripts/run_scmet.R "
        "--cell_feature {input.cell_feature} --output {output} --threads {threads} "
        "&> {log}"


rule run_epichaos_wcvi:
    input:
        manifest = op.join(SIM, "data", "wcvi_sweep", "manifest.tsv"),
        cpgs = op.join(SIM, "data", "wcvi_sweep", "cpgs.tsv"),
    output: op.join(SIM, "epichaos", "wcvi_sweep.epichaos.tsv")
    threads: 4
    conda: R_TOOLS_ENV
    benchmark: op.join(SIM, "benchmarks", "run_epichaos_wcvi.tsv")
    log: op.join(SIM, "logs", "run_epichaos_wcvi.log")
    shell:
        "Rscript workflow/scripts/run_epichaos.R "
        "--manifest {input.manifest} --cpg_reference {input.cpgs} "
        "--output {output} --threads {threads} --seed {config[sim][seed]} &> {log}"


rule run_epichaos_acvi:
    input:
        manifest = op.join(SIM, "data", "acvi_sweep", "manifest.tsv"),
        cpgs = op.join(SIM, "data", "acvi_sweep", "cpgs.tsv"),
    output: op.join(SIM, "epichaos", "acvi_sweep.epichaos.tsv")
    threads: 4
    conda: R_TOOLS_ENV
    benchmark: op.join(SIM, "benchmarks", "run_epichaos_acvi.tsv")
    log: op.join(SIM, "logs", "run_epichaos_acvi.log")
    shell:
        "Rscript workflow/scripts/run_epichaos.R "
        "--manifest {input.manifest} --cpg_reference {input.cpgs} "
        "--output {output} --threads {threads} --seed {config[sim][seed]} &> {log}"


rule eval_tool_comparison:
    input:
        wcvi_cell_feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.cell_feature.tsv.gz"),
        wcvi_feature = op.join(SIM, "amet", "wcvi_sweep", "wcvi_sweep.feature.tsv.gz"),
        wcvi_scmet = op.join(SIM, "scmet", "wcvi_sweep.scmet.tsv"),
        wcvi_epichaos = op.join(SIM, "epichaos", "wcvi_sweep.epichaos.tsv"),
        acvi_cell_feature = op.join(SIM, "amet", "acvi_sweep", "acvi_sweep.cell_feature.tsv.gz"),
        acvi_feature = op.join(SIM, "amet", "acvi_sweep", "acvi_sweep.feature.tsv.gz"),
        acvi_scmet = op.join(SIM, "scmet", "acvi_sweep.scmet.tsv"),
        acvi_epichaos = op.join(SIM, "epichaos", "acvi_sweep.epichaos.tsv"),
        wcvi_amet_bench = op.join(SIM, "benchmarks", "run_amet_wcvi_sweep.tsv"),
        acvi_amet_bench = op.join(SIM, "benchmarks", "run_amet_acvi_sweep.tsv"),
        wcvi_scmet_bench = op.join(SIM, "benchmarks", "run_scmet_wcvi.tsv"),
        acvi_scmet_bench = op.join(SIM, "benchmarks", "run_scmet_acvi.tsv"),
        wcvi_epichaos_bench = op.join(SIM, "benchmarks", "run_epichaos_wcvi.tsv"),
        acvi_epichaos_bench = op.join(SIM, "benchmarks", "run_epichaos_acvi.tsv"),
    output: op.join(SIM, "eval", "tool_comparison.pdf")
    params: prefix = op.join(SIM, "eval", "tool_comparison")
    log: op.join(SIM, "logs", "eval_tool_comparison.log")
    shell:
        "Rscript workflow/scripts/eval_tool_comparison.R "
        "--wcvi_cell_feature {input.wcvi_cell_feature} --wcvi_feature {input.wcvi_feature} "
        "--wcvi_scmet {input.wcvi_scmet} --wcvi_epichaos {input.wcvi_epichaos} "
        "--acvi_cell_feature {input.acvi_cell_feature} --acvi_feature {input.acvi_feature} "
        "--acvi_scmet {input.acvi_scmet} --acvi_epichaos {input.acvi_epichaos} "
        "--wcvi_amet_bench {input.wcvi_amet_bench} --acvi_amet_bench {input.acvi_amet_bench} "
        "--wcvi_scmet_bench {input.wcvi_scmet_bench} --acvi_scmet_bench {input.acvi_scmet_bench} "
        "--wcvi_epichaos_bench {input.wcvi_epichaos_bench} --acvi_epichaos_bench {input.acvi_epichaos_bench} "
        "--output_prefix {params.prefix} &> {log}"
