## amet simulations + evaluations.
##
## Tasks:
##   simulations: full validation grid (10 evaluations across 8 simulation scenarios)
##   ecker: TODO
##   argelaguet: TODO

import os.path as op

REPO_ROOT = op.dirname(workflow.basedir)
RESULTS = op.join(REPO_ROOT, "results")
AMET = op.join(REPO_ROOT, "method", "target", "release", "amet")

configfile: op.join(workflow.basedir, "config", "sim.yaml")

SIM = op.join(RESULTS, "simulations")

EVAL_OUTPUTS = [
    op.join(SIM, "eval", "p_decoupling.pdf"),
    op.join(SIM, "eval", "simulator_diagnostics.pdf"),
    op.join(SIM, "eval", "lag_profile.pdf"),
    op.join(SIM, "eval", "sparsity.pdf"),
    op.join(SIM, "eval", "feature_length.pdf"),
    op.join(SIM, "eval", "jsd_mixture_k.pdf"),
    op.join(SIM, "eval", "jsd_divergence.pdf"),
    op.join(SIM, "eval", "n_cells.pdf"),
    op.join(SIM, "eval", "vs_marginal_baseline.pdf"),
    op.join(SIM, "eval", "wcvi_recovery.pdf"),
    op.join(SIM, "eval", "acvi_recovery.pdf"),
    op.join(SIM, "eval", "benchmark_summary.pdf"),
    op.join(SIM, "eval", "tool_comparison.pdf"),
]

SIM_REPORT_HTML = op.join(SIM, "simulations_report.html")


rule all:
    input: SIM_REPORT_HTML


rule simulations:
    input: SIM_REPORT_HTML


rule render_simulations_report:
    input:
        rmd = op.join(REPO_ROOT, "workflow", "Rmd", "simulations_report.Rmd"),
        evals = EVAL_OUTPUTS,
    output: SIM_REPORT_HTML
    params:
        eval_dir = op.join(SIM, "eval"),
        out_dir = SIM,
    shell:
        r"""
        Rscript -e 'rmarkdown::render("{input.rmd}", output_file="simulations_report.html", output_dir="{params.out_dir}", params=list(eval_dir="{params.eval_dir}"), quiet=TRUE)'
        """


rule build_amet:
    output:
        binary = AMET,
    shell:
        "cd {REPO_ROOT}/method && cargo build --release"


# ----- p sweep -----

rule generate_p_sweep:
    output:
        manifest = op.join(SIM, "data", "p_sweep", "manifest.tsv"),
        cpgs = op.join(SIM, "data", "p_sweep", "cpgs.tsv"),
        bed = op.join(SIM, "data", "p_sweep", "feature.bed"),
    params:
        out_dir = op.join(SIM, "data", "p_sweep"),
        n_cells = config["sim"]["n_cells_per_condition"],
        n_cpgs = config["sim"]["n_cpgs"],
        persistence = config["sim"]["persistence"],
        p_grid = config["sim"]["p_grid"],
        seed = config["sim"]["seed"],
    shell:
        """
        Rscript workflow/scripts/generate_p_sweep.R \
            --out_dir {params.out_dir} \
            --n_cells_per_condition {params.n_cells} \
            --n_cpgs {params.n_cpgs} \
            --persistence {params.persistence} \
            --p_grid {params.p_grid} \
            --seed {params.seed}
        """


rule run_amet_p_sweep:
    input:
        manifest = op.join(SIM, "data", "p_sweep", "manifest.tsv"),
        cpgs = op.join(SIM, "data", "p_sweep", "cpgs.tsv"),
        bed = op.join(SIM, "data", "p_sweep", "feature.bed"),
        binary = AMET,
    output:
        cell_feature = op.join(SIM, "amet", "p_sweep", "p_sweep.cell_feature.tsv.gz"),
        feature = op.join(SIM, "amet", "p_sweep", "p_sweep.feature.tsv.gz"),
    params:
        prefix = op.join(SIM, "amet", "p_sweep", "p_sweep"),
        i_max_lag = config["amet"]["i_max_lag"],
        min_cpgs = config["amet"]["min_cpgs_per_feature"],
    shell:
        """
        mkdir -p $(dirname {params.prefix})
        {input.binary} --cpg-reference {input.cpgs} --features {input.bed} \
            --cells {input.manifest} --output-prefix {params.prefix} \
            --i-max-lag {params.i_max_lag} --min-cpgs-per-feature {params.min_cpgs}
        """


rule eval_p_decoupling:
    input: cell_feature = op.join(SIM, "amet", "p_sweep", "p_sweep.cell_feature.tsv.gz")
    output:
        op.join(SIM, "eval", "p_decoupling.pdf"),
        op.join(SIM, "eval", "p_decoupling.csv"),
    params: prefix = op.join(SIM, "eval", "p_decoupling")
    shell:
        "Rscript workflow/scripts/eval_p_decoupling.R "
        "--cell_feature {input.cell_feature} --output_prefix {params.prefix}"


rule eval_simulator_diagnostics:
    input: cell_feature = op.join(SIM, "amet", "p_sweep", "p_sweep.cell_feature.tsv.gz")
    output: op.join(SIM, "eval", "simulator_diagnostics.pdf")
    params: prefix = op.join(SIM, "eval", "simulator_diagnostics")
    shell:
        "Rscript workflow/scripts/eval_simulator_diagnostics.R "
        "--cell_feature {input.cell_feature} --output_prefix {params.prefix}"


rule eval_vs_marginal_baseline:
    input: cell_feature = op.join(SIM, "amet", "p_sweep", "p_sweep.cell_feature.tsv.gz")
