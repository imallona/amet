## amet simulations + evaluations.
##
## Tasks:
##   simulations: full validation grid (10 evaluations across 8 simulation scenarios)
##   ecker: TODO
##   argelaguet: TODO

import os
from pathlib import Path

REPO_ROOT = Path(workflow.basedir).parent
RESULTS = REPO_ROOT / "results"
AMET = REPO_ROOT / "method" / "target" / "release" / "amet"

configfile: "config/sim.yaml"

SIM = RESULTS / "simulations"

EVAL_OUTPUTS = [
    SIM / "eval/p_decoupling.pdf",
    SIM / "eval/simulator_diagnostics.pdf",
    SIM / "eval/persistence_response.pdf",
    SIM / "eval/lag_profile.pdf",
    SIM / "eval/sparsity.pdf",
    SIM / "eval/feature_length.pdf",
    SIM / "eval/jsd_mixture_k.pdf",
    SIM / "eval/jsd_divergence.pdf",
    SIM / "eval/n_cells.pdf",
    SIM / "eval/vs_marginal_baseline.pdf",
]


rule all:
    input:
        EVAL_OUTPUTS


rule simulations:
    input:
        EVAL_OUTPUTS


rule build_amet:
    output:
        binary = AMET,
    shell:
        "cd {REPO_ROOT}/method && cargo build --release"


def amet_inputs(scenario):
    base = SIM / f"data/{scenario}"
    return {
        "manifest": base / "manifest.tsv",
        "cpgs": base / "cpgs.tsv",
        "bed": base / "feature.bed",
        "binary": AMET,
    }


def amet_outputs(scenario):
    base = SIM / f"amet/{scenario}"
    return {
        "cell_feature": base / f"{scenario}.cell_feature.tsv.gz",
        "feature": base / f"{scenario}.feature.tsv.gz",
    }


def amet_shell(scenario, **kwargs):
    extra = " ".join(f"--{k.replace('_', '-')} {v}" for k, v in kwargs.items())
    base = SIM / f"amet/{scenario}"
    inputs = amet_inputs(scenario)
    return (
        f"mkdir -p {base} && "
        f"{inputs['binary']} "
        f"--cpg-reference {inputs['cpgs']} "
        f"--features {inputs['bed']} "
        f"--cells {inputs['manifest']} "
        f"--output-prefix {base}/{scenario} "
        f"--min-cpgs-per-feature {{cfg[min_cpgs]}} "
        f"--i-max-lag {{cfg[i_max_lag]}} "
        f"{extra}"
    )


# ----- p sweep (existing) -----

rule generate_p_sweep:
    output:
        manifest = SIM / "data/p_sweep/manifest.tsv",
        cpgs = SIM / "data/p_sweep/cpgs.tsv",
        bed = SIM / "data/p_sweep/feature.bed",
    params:
        out_dir = SIM / "data/p_sweep",
        n_cells = config["sim"]["n_cells_per_condition"],
        n_cpgs = config["sim"]["n_cpgs"],
        persistence = config["sim"]["persistence"],
        p_grid = config["sim"]["p_grid"],
        seed = config["sim"]["seed"],
    shell:
        """
        Rscript workflow/scripts/generate_p_sweep.R \
            --out_dir {params.out_dir} \
            --n_cells_per_condition {params.n_cells} \
            --n_cpgs {params.n_cpgs} \
            --persistence {params.persistence} \
            --p_grid {params.p_grid} \
            --seed {params.seed}
        """


rule run_amet_p_sweep:
    input: **amet_inputs("p_sweep")
    output: **amet_outputs("p_sweep")
    params:
        prefix = SIM / "amet/p_sweep/p_sweep",
        i_max_lag = config["amet"]["i_max_lag"],
        min_cpgs = config["amet"]["min_cpgs_per_feature"],
    shell:
        """
        mkdir -p $(dirname {params.prefix})
        {input.binary} --cpg-reference {input.cpgs} --features {input.bed} \
            --cells {input.manifest} --output-prefix {params.prefix} \
            --i-max-lag {params.i_max_lag} --min-cpgs-per-feature {params.min_cpgs}
        """


rule eval_p_decoupling:
    input: cell_feature = SIM / "amet/p_sweep/p_sweep.cell_feature.tsv.gz"
    output: SIM / "eval/p_decoupling.pdf", SIM / "eval/p_decoupling.csv"
    params: prefix = SIM / "eval/p_decoupling"
    shell:
        "Rscript workflow/scripts/eval_p_decoupling.R "
        "--cell_feature {input.cell_feature} --output_prefix {params.prefix}"


rule eval_simulator_diagnostics:
    input: cell_feature = SIM / "amet/p_sweep/p_sweep.cell_feature.tsv.gz"
